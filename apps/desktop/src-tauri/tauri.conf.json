{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Traicer",
  "version": "0.0.0",
  "identifier": "market.traice.traicer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "label": "main", "title": "Traicer", "width": 420, "height": 520, "visible": false }],
    "security": { "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* https://api.traice.market; style-src 'self' 'unsafe-inline'" }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/traicer-daemon"],
    "targets": "all"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/smashah/traicer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1OUM1NERCQjA2Njg3NEYKUldSUGgyYXcyMVNjTlI4dThiRzdYZGthQm55QittWFVkNHhQYVJrZ0ZKanNNUkhKNlIvY2lMblgK"
    }
  }
}
